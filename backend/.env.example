# Copy this file to .env and fill in real values. .env is gitignored.

# -----------------------------------------------------------------------------
# LLM PROVIDER — pick ONE of the three blocks below.
# Precedence in voice/agents.py: Ollama > OpenRouter > OpenAI.
# -----------------------------------------------------------------------------

# (A) Local Ollama — free, runs on your machine. Best for dev with a GPU.
#     Pull a tool-capable model first:  ollama pull qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENAI_AGENT_MODEL=qwen2.5:14b

# (B) OpenRouter — hosted, pay-as-you-go. Costs ~$0.0002 per test conversation.
#     Get a key at https://openrouter.ai/keys
#OPENROUTER_API_KEY=sk-or-v1-...
#OPENAI_AGENT_MODEL=openai/gpt-4o-mini

# (C) OpenAI directly — hosted, pay-as-you-go.
#OPENAI_API_KEY=sk-proj-...
#OPENAI_AGENT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Retell AI (not wired yet — leave as placeholders for now)
# -----------------------------------------------------------------------------
RETELL_API_KEY=your-retell-api-key-here
RETELL_AGENT_ID=your-retell-agent-id-here

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Change in production. Used to sign web-login JWTs.
JWT_SECRET_KEY=your-secret-key-change-in-production
